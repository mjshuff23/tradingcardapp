NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000
OCR_PROVIDER=tesseract
OCR_LANG=eng
OCR_DEBUG=false
LOOKUP_PROVIDERS=duckduckgo
# Optional for Google Vision reverse image lookup:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/gcp-service-account.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

DATABASE_URL=postgres://postgres:postgres@localhost:5433/tradingcarddb

S3_ENDPOINT=http://localhost:3900
S3_ACCESS_KEY=tradingcards
S3_SECRET_KEY=tradingcardssecret
S3_BUCKET=trading-cards
S3_PROFILE_BUCKET=trading-cards
S3_CARD_BUCKET=trading-cards
S3_REGION=garage

GARAGE_RPC_SECRET=change-me
GARAGE_ADMIN_TOKEN=change-me
GARAGE_METRICS_TOKEN=change-me
TAVILY_API_KEY=change-me
CARD_METADATA_ENRICHMENT_ENABLED=false
CARD_METADATA_ENRICHMENT_MODEL=gpt-4.1-mini
CARD_METADATA_ENRICHMENT_MAX_RESULTS=5
CARD_METADATA_ENRICHMENT_PROVIDER_ORDER=tavily,duckduckgo
