{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <12"
  },
  "scripts": {
    "dev": "npm run prisma:generate && nest start --watch",
    "start:dev": "npm run prisma:generate && nest start --watch",
    "build": "npm run prisma:generate && nest build",
    "start": "nest start",
    "prisma:generate": "prisma generate",
    "start:prod": "npm run db:prepare && node dist/main",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:export:catalog": "tsx prisma/export-catalog.ts",
    "db:seed": "prisma db seed",
    "db:prepare": "node prisma/prepare.js",
    "refresh:docker:backend": "npm --prefix ../.. run refresh:docker:backend",
    "infra:terraform:fmt": "npm --prefix ../.. run infra:terraform:fmt",
    "infra:terraform:validate": "npm --prefix ../.. run infra:terraform:validate",
    "test": "npm run prisma:generate && jest --config ./jest.config.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "npm run prisma:generate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.883.0",
    "@google-cloud/vision": "^5.3.4",
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.13",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "7.6.0",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "pg": "^8.16.3",
    "prisma": "7.6.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.0.0",
    "sharp": "^0.34.4",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.18",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/cookie-parser": "^1.4.8",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "dotenv": "^16.4.7",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.4.4",
    "ts-loader": "^9.0.0",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.0.0"
  }
}
