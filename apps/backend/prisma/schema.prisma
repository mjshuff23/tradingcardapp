generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Card {
  id            Int      @id @default(autoincrement())
  name          String
  set           String
  year          Int
  player        String
  imageUrl      String?
  gradeEstimate  String?
  user          User?    @relation(fields: [userId], references: [id])
  userId        Int?
}

model User {
  id    Int     @id @default(autoincrement())
  name  String
  cards Card[]
}
