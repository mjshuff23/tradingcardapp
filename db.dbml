Table users as U {
  id varchar [pk, note: 'UUID string']
  username varchar(100) [not null, unique, note: 'Account name']
  email varchar(320) [not null, unique, note: 'User email']
  password_hash varchar(255) [not null, note: 'Argon2id/bcrypt hash only; never store plaintext passwords']
  pfp_url varchar(2048) [note: 'Optional profile image URL; you may prefer storing an S3 object key and generating signed URLs']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`, note: 'Auto-update on write in application or database layer']
}

Table card_sets as CS {
  id varchar [pk, note: 'UUID string']
  brand varchar(100) [not null]
  set_name varchar(150) [not null]
  year_manufactured smallint [not null]
  sport varchar(50)
  season varchar(20)
  card_condition_scale varchar(50) [note: 'Set-level condition scale reference; owned copies still store actual condition']
  card_size varchar(50)
  card_thickness_pt smallint
  country_of_origin varchar(80)
  language varchar(50)
  material varchar(50)
  metadata jsonb [note: 'Optional set-level vendor IDs or ingestion metadata']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`, note: 'Auto-update on write in application or database layer']

  checks {
    `year_manufactured >= 1800 AND year_manufactured <= 2100` [name: 'chk_card_sets_year_manufactured_range']
    `card_thickness_pt IS NULL OR card_thickness_pt >= 0` [name: 'chk_card_sets_card_thickness_pt_nonnegative']
  }

  Indexes {
    (set_name)
    (brand)
    (year_manufactured)
    (brand, set_name, year_manufactured) [unique]
  }
}

Table card_definitions as CD {
  id varchar [pk, note: 'UUID string']
  card_set_id varchar [not null]
  card_number varchar(30) [not null]
  name varchar(200) [not null]
  category varchar(50) [note: 'Optional; consider enum later if values stabilize']
  subcategory varchar(50) [note: 'Optional, e.g. Anime, Comics, Film']
  has_autograph_variant boolean [not null, default: false]
  features jsonb [note: 'Optional list of features, e.g. Rookie, Holographic']
  original_or_reprint varchar(30) [note: 'Optional; consider enum later']
  parallel_or_variety varchar(100)
  set_type varchar(30) [note: 'Optional; consider enum later, e.g. Base or Insert']
  insert_set_name varchar(150)
  card_type varchar(50)
  is_vintage boolean [not null, default: false]
  metadata jsonb [note: 'Vendor IDs, scraped data, or other external metadata']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`, note: 'Auto-update on write in application or database layer']

  Indexes {
    (card_set_id)
    (name)
    (category)
    (card_set_id, card_number, name) [unique]
  }
}

Table user_cards as UC {
  id varchar [pk, note: 'UUID string']
  user_id varchar [not null]
  card_definition_id varchar [not null]

  condition varchar(50) [note: 'Condition for this specific copy']
  is_autographed boolean [not null, default: false]
  autograph_format varchar(50) [note: 'Optional, e.g. On-card or Sticker']

  front_image_key varchar(1024) [note: 'Optional S3 object key for front image']
  back_image_key varchar(1024) [note: 'Optional S3 object key for back image']

  is_for_trade boolean [not null, default: false]
  is_for_sale boolean [not null, default: false]
  asking_price_cents int
  notes varchar(2000) [note: 'Optional notes for this copy']

  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`, note: 'Auto-update on write in application or database layer']

  checks {
    `asking_price_cents IS NULL OR asking_price_cents >= 0` [name: 'chk_user_cards_asking_price_cents_nonnegative']
  }

  Indexes {
    (user_id)
    (card_definition_id)
    (user_id, card_definition_id)
  }
}

Table user_wishlist as WL {
  id varchar [pk, note: 'UUID string']
  user_id varchar [not null]
  card_definition_id varchar [not null]
  priority smallint [note: 'Optional interest level, e.g. 1 to 5']
  notes varchar(2000) [note: 'Optional wishlist notes or constraints']
  created_at timestamp [not null, default: `now()`]

  checks {
    `priority IS NULL OR (priority >= 1 AND priority <= 5)` [name: 'chk_user_wishlist_priority_range']
  }

  Indexes {
    (user_id)
    (card_definition_id)
    (user_id, card_definition_id) [unique]
  }
}

Ref: card_definitions.card_set_id > card_sets.id

Ref: user_cards.user_id > users.id
Ref: user_cards.card_definition_id > card_definitions.id

Ref: user_wishlist.user_id > users.id
Ref: user_wishlist.card_definition_id > card_definitions.id

