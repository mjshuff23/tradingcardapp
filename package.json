{
  "name": "trading-card-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.5.2",
  "description": "",
  "scripts": {
    "garage:config": "node scripts/generate-garage-config.js",
    "garage:bucket": "bash scripts/garage-bucket.sh",
    "infra:up": "npm run garage:config && docker compose up -d db garage",
    "infra:down": "docker compose stop db garage",
    "dev:docker": "npm run garage:config && docker compose up -d db garage backend frontend",
    "dev:docker:build": "npm run garage:config && docker compose up -d --build db garage backend frontend",
    "dev:local": "docker compose stop backend frontend >/dev/null 2>&1 || true && npm run infra:up && turbo run dev --parallel",
    "stop:local": "npm run infra:down",
    "clean:dev-cache": "bash scripts/fix-dev-perms.sh",
    "fix:docker-node-modules": "bash scripts/fix-docker-node-modules.sh",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "start": "turbo run start",
    "test:backend": "npm run test -w apps/backend",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "workspaces": [
    "apps/*"
  ],
  "dependencies": {
    "@prisma/client": "6.19.3"
  },
  "overrides": {
    "ajv": "8.18.0",
    "lodash": "4.18.1",
    "path-to-regexp": "8.4.2",
    "picomatch": "4.0.4"
  },
  "devDependencies": {
    "prisma": "6.19.3",
    "turbo": "^2.0.0"
  }
}
